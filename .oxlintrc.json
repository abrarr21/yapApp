{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import"],
  "env": {
    "es2024": true
  },
  "overrides": [
    {
      "files": ["client/**/*.{ts,tsx}"],
      "env": { "browser": true },
      "plugins": ["react", "react-hooks", "jsx-a11y"]
    },
    {
      "files": ["server/**/*.ts"],
      "env": { "node": true }
    }
  ]
}
